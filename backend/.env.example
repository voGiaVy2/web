# Database
# Mặc định khớp với docker-compose.yml (chạy `docker compose up -d` ở thư mục gốc dự án
# là dùng được ngay, không cần sửa dòng này). Khi deploy thật, thay bằng connection string
# MySQL của Railway.
DATABASE_URL="mysql://root:root@localhost:3306/tomam_db"

# Server
PORT=5000
NODE_ENV=production

# JWT
JWT_SECRET="thay-doi-chuoi-bi-mat-nay-that-dai-va-ngau-nhien"
JWT_EXPIRES_IN="7d"
JWT_RESET_SECRET="thay-doi-chuoi-bi-mat-reset-password-khac-voi-jwt-secret"
JWT_RESET_EXPIRES_IN="15m"

# Frontend URL (dùng cho link reset password / CORS)
CLIENT_URL="https://your-frontend.vercel.app"

# Email (SMTP - dùng Gmail App Password hoặc Mailtrap/SendGrid)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Phòng Trọ App <no-reply@phongtro.com>"

# Rate limit
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
